# Required when running with `readOnlyRootFilesystem: true`. Deluge extracts
# plugin eggs to PYTHON_EGG_CACHE; without this it would try to write to
# /home/deluge/.python-eggs on the read-only root and fail. /tmp is a tmpfs
# emptyDir mount in the StatefulSet.
PYTHON_EGG_CACHE=/tmp

DELUGE_LOGLEVEL=info

# Storage layout. /downloads is the NFS (or other shared) volume; per-pod
# .torrent file isolation is wired in statefulset.yaml via POD_NAME substitution.
DELUGE_CONF_CORE_TORRENTFILES_LOCATION=/downloads/torrents
DELUGE_CONF_CORE_DOWNLOAD_LOCATION=/downloads/pending
DELUGE_CONF_CORE_MOVE_COMPLETED=true
DELUGE_CONF_CORE_MOVE_COMPLETED_PATH=/downloads/complete
DELUGE_CONF_CORE_COPY_TORRENT_FILE=true

# Daemon
DELUGE_CONF_CORE_DAEMON_PORT=58846
DELUGE_CONF_CORE_ALLOW_REMOTE=TRUE

# Required for the per-pod listen port (61534 + pod_index) from
# inject_core_config.py to actually bind. Without this, Deluge defaults to
# random_port=true and ignores the assigned ports.
DELUGE_CONF_CORE_RANDOM_PORT=FALSE

# Peer discovery — disable services that don't make sense in a NATted /
# cluster-routed deployment. Adjust to taste.
DELUGE_CONF_CORE_LSD=FALSE
DELUGE_CONF_CORE_UPNP=FALSE
DELUGE_CONF_CORE_NATPMP=FALSE

# Plugins
DELUGE_CONF_CORE_PLUGINS_LOCATION=/home/deluge/.config/deluge/plugins
DELUGE_CONF_CORE_ENABLED_PLUGINS=[ltConfig,Label]

# Web UI
DELUGE_CONF_WEB_PORT=8112
DELUGE_CONF_WEB_HTTPS=false
DELUGE_CONF_WEB_BASE=/
